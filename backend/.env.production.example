# ─────────────────────────────────────────────
# PRODUCTION ENV TEMPLATE (for Render deployment)
# Do NOT use this file locally — your local .env stays as-is.
# Fill these values into Render's Environment Variables dashboard.
# ─────────────────────────────────────────────

PORT=5001

# TiDB Cloud connection details (from your TiDB Cloud dashboard → Connect)
DB_HOST=your-tidb-cluster-host.tidbcloud.com
DB_PORT=4000
DB_USER=your_tidb_username
DB_PASSWORD=your_tidb_password
DB_NAME=mobilisdb
DB_SSL=true

# Use a strong random string in production (different from local dev secret)
JWT_SECRET=replace_with_a_long_random_production_secret

# Binance keys (only needed for real trading — leave blank for paper trading)
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Comma-separated list of allowed frontend origins.
# Include BOTH your local dev URL and your deployed Vercel URL if you want both to work.
CLIENT_URL=http://localhost:5173,https://your-app-name.vercel.app
