# ─────────────────────────────────────────────
# FRONTEND PRODUCTION ENV (for Vercel deployment)
# Do NOT use this locally — local dev needs no env file, Vite's proxy handles it.
# Add these in Vercel's dashboard → Project → Settings → Environment Variables.
# ─────────────────────────────────────────────

# Your deployed Render backend URL + /api
VITE_API_URL=https://your-backend-name.onrender.com/api

# Your deployed Render backend URL as wss:// + /ws/btc-price
VITE_WS_URL=wss://your-backend-name.onrender.com/ws/btc-price
